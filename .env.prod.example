APP_ENV=prod
GIN_MODE=release
IMAGE_TAG=latest

# PostgreSQL（建议使用内网地址）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DBNAME=luke-chu-site
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=50
POSTGRES_MAX_IDLE_CONNS=25
POSTGRES_CONN_MAX_LIFETIME_MINUTES=30

# 日志等级：debug / info / warn / error
LOG_LEVEL=info

# OSS（仅占位示例，勿提交真实密钥）
OSS_ACCESS_KEY_ID=replace-with-access-key-id
OSS_ACCESS_KEY_SECRET=replace-with-access-key-secret
OSS_SESSION_TOKEN=
OSS_BUCKET_NAME=luke-chu-site-photography
OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com
OSS_PUBLIC_BASE_URL=https://luke-chu-site-photography.oss-cn-hongkong.aliyuncs.com
OSS_REGION=cn-hongkong
OSS_PRESIGN_EXPIRE_SECONDS=300

# 行为风控
SECURITY_BEHAVIOR_ENABLED=true
SECURITY_BEHAVIOR_WINDOW_SECONDS=60
SECURITY_BEHAVIOR_IP_LIMIT_PER_WINDOW=180
SECURITY_BEHAVIOR_SUSPICIOUS_IP_LIMIT_PER_WINDOW=30
